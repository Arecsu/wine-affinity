@@ -41,6 +55,49 @@ static inline struct dxcore_adapter *impl_from_IDXCoreAdapter(IDXCoreAdapter *if
     return CONTAINING_RECORD(iface, struct dxcore_adapter, IDXCoreAdapter_iface);
 }
 
+static void dxcore_adapter_ensure_dxgi(struct dxcore_adapter *adapter)
+{
+    IDXGIFactory1 *factory;
+    IDXGIAdapter1 *dxgi_a;
+    UINT i = 0;
+
+    if (adapter->dxgi_adapter_tried)
+        return;
+    adapter->dxgi_adapter_tried = TRUE;
+
+    if (FAILED(CreateDXGIFactory1(&IID_IDXGIFactory1, (void **)&factory)))
+        return;
+
+    FIXME("dxcore_adapter_ensure_dxgi: adapter identifier vendor_id=0x%04x device_id=0x%04x luid=%u:%d\n",
+          adapter->identifier.vendor_id, adapter->identifier.device_id,
+          adapter->identifier.adapter_luid.LowPart, adapter->identifier.adapter_luid.HighPart);
+
+    while (IDXGIFactory1_EnumAdapters1(factory, i++, &dxgi_a) == S_OK)
+    {
+        DXGI_ADAPTER_DESC1 desc;
+        IDXGIAdapter1_GetDesc1(dxgi_a, &desc);
+        FIXME("dxcore_adapter_ensure_dxgi: DXGI adapter %u: VendorId=0x%04x DeviceId=0x%04x LUID=%u:%d\n",
+              i - 1, desc.VendorId, desc.DeviceId, desc.AdapterLuid.LowPart, desc.AdapterLuid.HighPart);
+        if (desc.AdapterLuid.LowPart == adapter->identifier.adapter_luid.LowPart
+                && desc.AdapterLuid.HighPart == adapter->identifier.adapter_luid.HighPart)
+        {
+            adapter->dxgi_adapter = dxgi_a;
+            /* Also fill in accurate PCI IDs */
+            adapter->dxgi_vendor_id  = desc.VendorId;
+            adapter->dxgi_device_id  = desc.DeviceId;
+            adapter->dxgi_sub_sys_id = desc.SubSysId;
+            adapter->dxgi_revision   = desc.Revision;
+            adapter->dxgi_valid      = TRUE;
+            FIXME("dxcore_adapter_ensure_dxgi: MATCHED! Using DXGI vendor=0x%04x device=0x%04x\n",
+                  desc.VendorId, desc.DeviceId);
+            break;
+        }
+        IDXGIAdapter1_Release(dxgi_a);
+    }
+
+    IDXGIFactory1_Release(factory);
+}
+
 static HRESULT STDMETHODCALLTYPE dxcore_adapter_QueryInterface(IDXCoreAdapter *iface, REFIID riid, void **out)
 {
     struct dxcore_adapter *adapter = impl_from_IDXCoreAdapter(iface);
@@ -55,6 +112,16 @@ static HRESULT STDMETHODCALLTYPE dxcore_adapter_QueryInterface(IDXCoreAdapter *i
         return S_OK;
     }
 
+    /* Affinity queries for IDXGIAdapter to check D3D12 feature level support */
+    if (IsEqualGUID(riid, &IID_IDXGIAdapter)
+            || IsEqualGUID(riid, &IID_IDXGIAdapter1)
+            || IsEqualGUID(riid, &IID_IDXGIObject))
+    {
+        dxcore_adapter_ensure_dxgi(adapter);
+        if (adapter->dxgi_adapter)
+            return IDXGIAdapter1_QueryInterface(adapter->dxgi_adapter, riid, out);
+    }
+
     FIXME("%s not implemented, returning E_NOINTERFACE.\n", debugstr_guid(riid));
     *out = NULL;
     return E_NOINTERFACE;
