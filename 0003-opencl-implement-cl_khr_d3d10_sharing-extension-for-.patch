+static void get_adapters_dxgi_info(struct dxcore_adapter_list *list)
+{
+    IDXGIFactory1 *factory = NULL;
+    UINT dxgi_idx = 0;
+
+    if (FAILED(CreateDXGIFactory1(&IID_IDXGIFactory1, (void **)&factory)))
+        return;
+
+    for (UINT i = 0; i < list->adapter_count; i++)
+    {
+        IDXGIAdapter *adapter = NULL;
+        DXGI_ADAPTER_DESC desc;
+
+        if (SUCCEEDED(IDXGIFactory1_EnumAdapters(factory, dxgi_idx, &adapter)))
+        {
+            if (SUCCEEDED(IDXGIAdapter_GetDesc(adapter, &desc)))
+            {
+                list->adapters[i]->dxgi_vendor_id  = desc.VendorId;
+                list->adapters[i]->dxgi_device_id  = desc.DeviceId;
+                list->adapters[i]->dxgi_sub_sys_id = desc.SubSysId;
+                list->adapters[i]->dxgi_revision   = desc.Revision;
+                list->adapters[i]->dxgi_valid       = TRUE;
+            }
+            IDXGIAdapter_Release(adapter);
+            dxgi_idx++;
+        }
+    }
+
+    IDXGIFactory1_Release(factory);
+}
+
 static HRESULT get_adapters(struct dxcore_adapter_list *list)
 {
     struct wined3d *wined3d = wined3d_create(0);
@@ -491,6 +615,9 @@ static HRESULT get_adapters(struct dxcore_adapter_list *list)
             goto done;
     }
 
+    /* Fill in accurate PCI IDs via DXGI (wined3d may return zeros without a display) */
+    get_adapters_dxgi_info(list);
+
 done:
     wined3d_decref(wined3d);
     return hr;
